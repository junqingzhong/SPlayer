{
  "name": "splayer",
  "productName": "SPlayer",
  "desktopName": "top.imsyy.SPlayer",
  "version": "3.1.1",
  "packageManager": "pnpm@10.28.1",
  "description": "A minimalist music player",
  "main": "./out/main/index.js",
  "author": "imsyy",
  "home": "https://imsyy.top",
  "github": "https://github.com/SPlayer-Dev/SPlayer",
  "blog": "https://blog.imsyy.top",
  "repository": "github:SPlayer-Dev/SPlayer",
  "license": "AGPL-3.0",
  "license-file": "LICENSE",
  "engines": {
    "node": ">=20",
    "npm": ">=11",
    "pnpm": ">=10"
  },
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --max-warnings=0",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "build:native": "tsx scripts/build-native.ts",
    "start": "electron-vite preview",
    "dev": "pnpm build:native -- --dev && tsx scripts/dev.ts",
    "build": "rimraf dist && pnpm build:native && pnpm typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:web": "pnpm build",
    "build:unpack": "pnpm build && electron-builder --dir",
    "build:win": "pnpm build && electron-builder --win --config electron-builder.config.ts",
    "build:mac": "pnpm build && electron-builder --mac --config electron-builder.config.ts",
    "build:linux": "pnpm build && electron-builder --linux --config electron-builder.config.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@applemusic-like-lyrics/core": "^0.5.1",
    "@applemusic-like-lyrics/lyric": "^1.0.1",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@imsyy/color-utils": "^1.0.2",
    "@material/material-color-utilities": "^0.4.0",
    "@neteasecloudmusicapienhanced/api": "^4.34.3",
    "@pixi/app": "^7.4.3",
    "@pixi/core": "^7.4.3",
    "@pixi/display": "^7.4.3",
    "@pixi/filter-blur": "^7.4.3",
    "@pixi/filter-bulge-pinch": "^5.1.1",
    "@pixi/filter-color-matrix": "^7.4.3",
    "@pixi/sprite": "^7.4.3",
    "@vueuse/core": "^14.3.0",
    "@vueuse/integrations": "^14.3.0",
    "axios": "^1.17.0",
    "axios-retry": "^4.5.0",
    "better-sqlite3": "^12.10.0",
    "change-case": "^5.4.4",
    "dayjs": "^1.11.21",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "file-saver": "^2.0.5",
    "font-list": "^2.1.0",
    "fuse.js": "^7.4.1",
    "get-port": "^7.2.0",
    "github-markdown-css": "^5.9.0",
    "js-cookie": "^3.0.8",
    "jss": "^10.10.0",
    "jss-preset-default": "^10.10.0",
    "localforage": "^1.10.0",
    "lodash-es": "^4.18.1",
    "marked": "^16.4.2",
    "md5": "^2.3.0",
    "music-metadata": "^11.12.3",
    "p-limit": "^7.3.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "plyr": "^3.8.4",
    "sortablejs": "^1.15.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4",
    "@fastify/cookie": "^11.0.2",
    "@fastify/http-proxy": "^11.4.4",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^8.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/emscripten": "^1.41.5",
    "@types/file-saver": "^2.0.7",
    "@types/js-cookie": "^3.0.6",
    "@types/md5": "^2.3.6",
    "@types/node": "^24.13.0",
    "@types/sortablejs": "^1.15.9",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "ajv": "^8.20.0",
    "crypto-js": "^4.2.0",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "electron-log": "^5.4.4",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^9.33.0",
    "fast-glob": "^3.3.3",
    "fastify": "^5.8.5",
    "naive-ui": "2.43.2",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "sass": "^1.100.0",
    "terser": "^5.48.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^7.3.5",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vite-plugin-wasm": "^3.6.0",
    "vitepress": "2.0.0-alpha.15",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0",
    "vue-tsc": "^3.3.3"
  },
  "pnpm": {
    "overrides": {
      "dmg-builder": "26.0.12",
      "electron-builder-squirrel-windows": "26.0.12"
    },
    "onlyBuiltDependencies": [
      "@applemusic-like-lyrics/core",
      "@applemusic-like-lyrics/lyric",
      "@parcel/watcher",
      "better-sqlite3",
      "core-js",
      "electron",
      "electron-winstaller",
      "esbuild",
      "sharp",
      "vue-demi"
    ],
    "ignoredBuiltDependencies": [
      "register-scheme",
      "wasm-pack"
    ]
  }
}
